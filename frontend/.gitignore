```gitignore
# ==========================
# Dependencies
# ==========================
node_modules/
frontend/node_modules/
backend/node_modules/

# ==========================
# Build Output
# ==========================
dist/
build/
frontend/dist/
backend/dist/
dist-ssr/

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================
# Environment Files
# ==========================
# .env
# .env.*
# !.env.example
# *.local

# ==========================
# Coverage
# ==========================
coverage/

# ==========================
# Runtime Files
# ==========================
*.pid
*.seed

# ==========================
# Editor / IDE
# ==========================
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db
```
